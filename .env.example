# ── Sarvam AI ─────────────────────────────────────────────────────────────────
SARVAM_API_KEY=
SARVAM_LLM_BASE_URL=https://api.sarvam.ai/v1
SARVAM_LLM_MODEL=sarvam-m
SARVAM_STT_WS_BASE=wss://api.sarvam.ai/speech-to-text/ws
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_LANGUAGE=hi-IN
SARVAM_VOICE=simran

# ── Twilio ─────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Tunnel / server ────────────────────────────────────────────────────────────
NGROK_URL=
PORT=5050

# ── /make-call API key (leave blank to disable auth) ──────────────────────────
MAKE_CALL_API_KEY=

# ── Default call target (used when launching via CLI) ─────────────────────────
CALL_TO=

# ── Default customer data (overridden per-call via /make-call body) ───────────
DEFAULT_CUSTOMER_NAME=Mr. Sharma
DEFAULT_LENDER=Easy Home Finance
DEFAULT_LOAN_TYPE=Home Loan
DEFAULT_ACCOUNT_LAST4=4321
DEFAULT_EMI_DUE_DATE=5
DEFAULT_EMI_AMOUNT=15500
DEFAULT_EMI_AMOUNT_WORDS=पंद्रह हज़ार पाँच सौ

# ── Runtime tunables ───────────────────────────────────────────────────────────
HANGUP_GRACE_SEC=1.8
SILENCE_TIMEOUT_SEC=25.0
LLM_MAX_TOKENS=90
LLM_TEMPERATURE=0.3
TTS_PACE=1.1
MIN_WORDS=2
TRANSCRIPTS_DIR=transcripts
